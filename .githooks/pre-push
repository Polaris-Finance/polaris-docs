#!/usr/bin/env sh
set -eu

if [ "${SKIP_LOCAL_PUSH_GATE:-}" = "1" ]; then
  echo "Skipping local push gate because SKIP_LOCAL_PUSH_GATE=1." >&2
  exit 0
fi

should_run=0
while read local_ref local_oid remote_ref remote_oid
do
  case "$local_oid" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  case "$remote_ref" in
    refs/heads/*)
      should_run=1
      ;;
  esac
done

if [ "$should_run" -eq 0 ]; then
  exit 0
fi

if [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ]; then
  # shellcheck disable=SC1090
  . "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  if [ -f .nvmrc ]; then
    nvm use --silent >/dev/null || true
  fi
fi

npm run local:push-gate
