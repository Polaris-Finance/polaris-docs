{
  "name": "polaris-docs",
  "version": "0.1.0",
  "private": true,
  "description": "User documentation for Polaris Finance — the pETH-powered yield layer for all of DeFi.",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22 <27",
    "npm": ">=10"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "predev": "node scripts/sync-pagefind.mjs --if-exists",
    "dev": "node scripts/dev.mjs",
    "dev:search": "npm run build && npm run dev",
    "generate": "node scripts/generate-sitemap.mjs && node scripts/generate-llms.mjs",
    "export:gdocs": "python3 scripts/export-gdocs-review.py",
    "import:gdocs": "python3 scripts/import-gdocs-review.py",
    "test:gdocs-roundtrip": "python3 scripts/test-gdocs-roundtrip.py",
    "clean:export": "node scripts/clean-export.mjs",
    "prebuild": "node scripts/clean-export.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-llms.mjs",
    "build": "next build --webpack",
    "postbuild": "pagefind --site out --output-subdir _pagefind && node scripts/sync-pagefind.mjs",
    "ci": "npm run ci:source && npm run build && npm run ci:artifact && npm run audit:prod",
    "ci:source": "npm run lint && npm run format:check && npm run lint:content && npm run test:gdocs-roundtrip && npm run check:links && npm run check:generated && npm run check:host",
    "ci:artifact": "npm run check:artifact && npm run check:pagefind && npm run check:navigation && npm run check:gdocs-import && npm run test:e2e:artifact",
    "lint": "eslint .",
    "format": "prettier --write \"{app,components,scripts,tests}/**/*.{js,jsx,mjs,css}\" \"*.{mjs,json}\" \".github/workflows/*.{yml,yaml}\"",
    "format:check": "prettier --check \"{app,components,scripts,tests}/**/*.{js,jsx,mjs,css}\" \"*.{mjs,json}\" \".github/workflows/*.{yml,yaml}\"",
    "lint:content": "node scripts/check-content.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:links:external": "node scripts/check-links.mjs --external",
    "check:generated": "node scripts/generate-sitemap.mjs --check && node scripts/generate-llms.mjs --check",
    "check:artifact": "node scripts/check-export-artifact.mjs",
    "check:gdocs-import": "node scripts/check-gdocs-import.mjs",
    "check:live-artifact": "node scripts/check-live-artifact.mjs",
    "check:host": "node scripts/check-host-consistency.mjs",
    "check:navigation": "node scripts/check-navigation-integrity.mjs",
    "check:pagefind": "node scripts/check-pagefind.mjs",
    "sync:pagefind": "node scripts/sync-pagefind.mjs",
    "test:e2e": "playwright test",
    "test:e2e:artifact": "PLAYWRIGHT_REUSE_EXPORT=1 playwright test",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "local:push-gate": "node scripts/local-push-gate.mjs",
    "local:push-gate:strict-node": "node scripts/local-push-gate.mjs --strict-node",
    "start": "npm run serve",
    "serve": "node scripts/serve-export.mjs"
  },
  "dependencies": {
    "next": "^16.2.9",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "github-slugger": "^2.0.0",
    "globals": "^17.6.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4"
  },
  "overrides": {
    "postcss": "8.5.10",
    "zod": "4.1.12"
  }
}
